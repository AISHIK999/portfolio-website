DATABASE_URL=postgres://neondb_owner:<change_neondb_user>@<neondb_deployment_url>/neondb?sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:<change_neondb_user>@<neondb_deployment_url>/neondb?sslmode=require

# Parameters for constructing your own connection string
PGHOST=get_these_variables_from_neondb_console
PGHOST_UNPOOLED=get_these_variables_from_neondb_console
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=get_these_variables_from_neondb_console

# Parameters for Vercel Postgres Templates
POSTGRES_URL=get_these_variables_from_neondb_console
POSTGRES_URL_NON_POOLING=get_these_variables_from_neondb_console
POSTGRES_USER=neondb_owner
POSTGRES_HOST=get_these_variables_from_neondb_console
POSTGRES_PASSWORD=get_these_variables_from_neondb_console
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=get_these_variables_from_neondb_console
POSTGRES_PRISMA_URL=get_these_variables_from_neondb_console
